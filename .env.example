# Required by the agent harness (apps/server -> packages/core)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the default model (defaults to claude-opus-4-8)
# MODEL=claude-opus-4-8

# Web -> server WebSocket URL. Baked into the Next.js bundle at BUILD time.
# Local dev default is ws://localhost:8080
# NEXT_PUBLIC_WS_URL=wss://your-server.up.railway.app
